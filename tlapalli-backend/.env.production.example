# =============================================================================
# TLAPALLI - PRODUCCIÓN ENVIRONMENT VARIABLES
# =============================================================================
# Este archivo es una referencia de las variables que debes configurar
# en tu proveedor cloud (Koyeb, Render, etc.)
# NO USES ESTE ARCHIVO DIRECTAMENTE - configura cada variable como secret/env var
# en el panel de control de tu hosting.

# ===== REQUERIDAS =====

# Base de datos
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/tlapalli?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/tlapalli?sslmode=require"

# JWT - Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="<generar-secreto-fuerte-64-hex-chars>"
JWT_EXPIRATION="15m"
REFRESH_TOKEN_SECRET="<generar-secreto-fuerte-64-hex-chars>"
REFRESH_TOKEN_EXPIRATION="7d"

# URLs de producción
FRONTEND_URL="https://tlapalli.vercel.app"
GOOGLE_CALLBACK_URL="https://tlapalli-backend.koyeb.app/auth/google/callback"

# Google OAuth
GOOGLE_CLIENT_ID="<tu-google-client-id>"
GOOGLE_CLIENT_SECRET="<tu-google-client-secret>"

# Email
SENDGRID_API_KEY="<tu-sendgrid-api-key>"
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="<tu-sendgrid-api-key>"
SMTP_FROM="TLAPALLI <noreply@tlapalli.com>"

# Cloudinary
CLOUDINARY_CLOUD_NAME="<tu-cloud-name>"
CLOUDINARY_API_KEY="<tu-api-key>"
CLOUDINARY_API_SECRET="<tu-api-secret>"

# ===== OPCIONALES =====
NODE_ENV="production"
PORT="3000"
