# =============================================================================
# TLAPALLI - Configuración de Entorno
# =============================================================================
# Copia este archivo a .env y completa los valores
# cp .env.example .env

# =============================================================================
# BASE DE DATOS (PostgreSQL - Neon)
# =============================================================================
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/tlapalli?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/tlapalli?sslmode=require"

# =============================================================================
# JWT (Autenticación)
# =============================================================================
# Genera un secreto fuerte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambiar-por-valor-secreto-de-64-caracteres-hex"
JWT_EXPIRATION="15m"
REFRESH_TOKEN_SECRET="cambiar-por-valor-secreto-de-64-caracteres-hex"
REFRESH_TOKEN_EXPIRATION="7d"

# =============================================================================
# URLs
# =============================================================================
# Para desarrollo:
FRONTEND_URL="http://localhost:5173"
# Para producción (descomenta y configura):
# FRONTEND_URL="https://tlapalli.vercel.app"

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
# Crea credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Para desarrollo:
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
# Para producción (descomenta y configura):
# GOOGLE_CALLBACK_URL="https://tu-backend.koyeb.app/auth/google/callback"

# =============================================================================
# EMAIL (SendGrid)
# =============================================================================
SENDGRID_API_KEY="SG.tu-api-key-de-sendgrid"
# Alternativa SMTP:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-app-password"
SMTP_FROM="TLAPALLI <noreply@tlapalli.com>"

# =============================================================================
# CLOUDINARY (Almacenamiento de archivos)
# =============================================================================
# Configura en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"
