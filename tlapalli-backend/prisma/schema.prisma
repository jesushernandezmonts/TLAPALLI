// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               Int            @id @default(autoincrement())
  nombre           String
  email            String         @unique
  passwordHash     String?        @map("password_hash") // Optional if using Google only
  googleId         String?        @unique @map("google_id")
  fotoUrl          String?        @map("foto_url")
  rol              String         @default("profesor") // admin o profesor
  intentosFallidos Int            @default(0) @map("intentos_fallidos")
  bloqueadoHasta   DateTime?      @map("bloqueado_hasta")
  resetToken       String?        @unique @map("reset_token")
  resetTokenExp    DateTime?      @map("reset_token_exp")
  instructorId     Int?           @unique @map("instructor_id")
  instructor       Instructor?    @relation(fields: [instructorId], references: [id])
  refreshTokens    RefreshToken[]
  creadoEn         DateTime       @default(now()) @map("creado_en")
  pagos            Pago[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  usuarioId Int      @map("usuario_id")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiraEn  DateTime @map("expira_en")
  revocado  Boolean  @default(false)
  creadoEn  DateTime @default(now()) @map("creado_en")
}

model Alumno {
  id               Int           @id @default(autoincrement())
  nombre           String
  apellidoPaterno  String        @map("apellido_paterno")
  apellidoMaterno  String?       @map("apellido_materno")
  curp             String?       @unique
  fechaNacimiento  DateTime?     @map("fecha_nacimiento")
  telefono         String?
  padecimientos    String?
  barrioComunidad  String?       @map("barrio_comunidad")
  estatusActivo    Boolean       @default(true) @map("estatus_activo")
  fotoUrl          String?       @map("foto_url")
  // Autenticación para alumnos
  email            String?       @unique
  passwordHash     String?       @map("password_hash")
  authActivo       Boolean       @default(false) @map("auth_activo")
  resetToken       String?       @unique @map("reset_token")
  resetTokenExp    DateTime?     @map("reset_token_exp")
  // Relaciones existentes
  inscripciones    Inscripcion[]
  pagos            Pago[]
  documentos       Documento[]
  grupos           GrupoAlumno[] @relation("GrupoAlumnos")
  // Nuevas relaciones
  servicioSocial   ServicioSocial[]
  alumnoRefreshTokens AlumnoRefreshToken[]
}

model Documento {
  id        Int      @id @default(autoincrement())
  nombre    String
  tipo      String   // acta_nacimiento, curp, comprobante_domicilio, identificacion, foto, constancia_medica, otro
  url       String
  alumnoId  Int      @map("alumno_id")
  alumno    Alumno   @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  subidoEn  DateTime @default(now()) @map("subido_en")
}

model Taller {
  id                Int           @id @default(autoincrement())
  nombreTaller      String        @unique @map("nombre_taller")
  descripcion       String?
  costoMensual      Decimal       @map("costo_mensual") @db.Decimal(10, 2)
  cupoMaximo        Int           @map("cupo_maximo")
  horarioDescripcion String?      @map("horario_descripcion")
  activo            Boolean       @default(true)
  inscripciones     Inscripcion[]
  instructores      Instructor[]
  justificaciones   JustificacionInstructor[]
}

model Instructor {
  id            Int      @id @default(autoincrement())
  nombre        String
  email         String?  @unique
  telefono      String?
  estado        String   @default("Pendiente") // Pendiente, Activo, Inactivo
  activo        Boolean  @default(true)
  tallerId      Int?     @map("taller_id")
  taller        Taller?  @relation(fields: [tallerId], references: [id])
  usuario       Usuario?
  temarioUrl    String?  @map("temario_url")
  curriculumUrl String?  @map("curriculum_url")
  grupos        Grupo[]
  justificaciones JustificacionInstructor[]
}

model Inscripcion {
  id               Int          @id @default(autoincrement())
  alumnoId         Int          @map("alumno_id")
  tallerId         Int          @map("taller_id")
  fechaInscripcion DateTime     @default(now()) @map("fecha_inscripcion")
  estatusPago      String       @default("pendiente") @map("estatus_pago") // pendiente, al_corriente, deudor
  periodo          String       @default("ordinario") // 'ordinario' | 'verano'
  anio             Int          @default(2026)
  alumno           Alumno       @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  taller           Taller       @relation(fields: [tallerId], references: [id])
  asistencias      Asistencia[]
}

model Asistencia {
  id             Int          @id @default(autoincrement())
  inscripcionId  Int?         @map("inscripcion_id")
  fecha          DateTime     @default(now())
  estado         String       // asistencia, falta
  observaciones  String?
  inscripcion    Inscripcion? @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)

  // Relación opcional con GrupoAlumno para pasar lista por grupos
  grupoAlumnoId  Int?         @map("grupo_alumno_id")
  grupoAlumno    GrupoAlumno? @relation(fields: [grupoAlumnoId], references: [id], onDelete: Cascade)
}

model Pago {
  id                Int       @id @default(autoincrement())
  alumnoId          Int       @map("alumno_id")
  monto             Decimal   @db.Decimal(10, 2)
  fechaPago         DateTime  @default(now()) @map("fecha_pago")
  mesCorrespondiente String  @map("mes_correspondiente")
  metodoPago        String?   @map("metodo_pago") // efectivo, transferencia
  registradoPor     Int?      @map("registrado_por")
  alumno            Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  usuario           Usuario?  @relation(fields: [registradoPor], references: [id])
}

model Actividad {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String?
  fecha       DateTime
  tipo        String   // 'interna' | 'externa'
  ubicacion   String   // 'galeria' | 'audioteca' | 'auditorio'
  creadoEn    DateTime @default(now()) @map("creado_en")
}

model Reporte {
  id        Int      @id @default(autoincrement())
  tipo      String   // general, financiero, alumnos, talleres, actividades
  nombre    String
  url       String
  creadoEn  DateTime @default(now()) @map("creado_en")
}

model Grupo {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String?
  instructorId  Int       @map("instructor_id")
  instructor    Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")
  alumnos       GrupoAlumno[]

  @@index([instructorId])
}

model GrupoAlumno {
  id          Int         @id @default(autoincrement())
  grupoId     Int         @map("grupo_id")
  alumnoId    Int         @map("alumno_id")
  grupo       Grupo       @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  alumno      Alumno      @relation("GrupoAlumnos", fields: [alumnoId], references: [id], onDelete: Cascade)
  creadoEn    DateTime    @default(now()) @map("creado_en")
  asistencias Asistencia[]

  @@unique([grupoId, alumnoId])
  @@index([grupoId])
  @@index([alumnoId])
}

// === SERVICIO SOCIAL ===
model ServicioSocial {
  id                Int                        @id @default(autoincrement())
  alumnoId          Int                        @map("alumno_id")
  alumno            Alumno                     @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  horasRequeridas   Int                        @default(480) @map("horas_requeridas")
  horasCompletadas  Int                        @default(0) @map("horas_completadas")
  estatus           String                     @default("en_curso") // en_curso, completado, suspendido, baja
  institucion       String?                    // Institución donde se presta el servicio
  programa          String?                    // Nombre del programa o área
  fechaInicio       DateTime?                  @map("fecha_inicio")
  fechaFin          DateTime?                  @map("fecha_fin")
  supervisor        String?                    // Nombre del supervisor
  observaciones     String?
  actividades       ActividadServicioSocial[]
  creadoEn          DateTime                   @default(now()) @map("creado_en")
  actualizadoEn     DateTime                   @updatedAt @map("actualizado_en")

  @@index([alumnoId])
}

model ActividadServicioSocial {
  id              Int            @id @default(autoincrement())
  servicioSocialId Int           @map("servicio_social_id")
  servicioSocial  ServicioSocial @relation(fields: [servicioSocialId], references: [id], onDelete: Cascade)
  fecha           DateTime       @default(now())
  horas           Int
  descripcion     String
  comentarios     String?
  estatus         String         @default("aprobada") // pendiente, aprobada, rechazada
  evidenciaUrl    String?        @map("evidencia_url")
  creadoEn        DateTime       @default(now()) @map("creado_en")

  @@index([servicioSocialId])
}

// === REFRESH TOKENS PARA ALUMNOS ===
model AlumnoRefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  alumnoId  Int      @map("alumno_id")
  alumno    Alumno   @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  expiraEn  DateTime @map("expira_en")
  revocado  Boolean  @default(false)
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([alumnoId])
}

// === JUSTIFICACIONES DE INSTRUCTORES ===
model JustificacionInstructor {
  id                 Int         @id @default(autoincrement())
  instructorId       Int         @map("instructor_id")
  tallerId           Int?        @map("taller_id")
  fechaFalta         DateTime    @map("fecha_falta")
  motivo             String
  comprobanteUrl     String?     @map("comprobante_url")
  estatus            String      @default("pendiente") // pendiente, aprobada, rechazada
  observacionesAdmin String?     @map("observaciones_admin")
  creadoEn           DateTime    @default(now()) @map("creado_en")
  actualizadoEn      DateTime    @updatedAt @map("actualizado_en")

  instructor         Instructor  @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  taller             Taller?     @relation(fields: [tallerId], references: [id])

  @@index([instructorId])
}

